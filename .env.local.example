# ─── CONTACT FORM ────────────────────────────────────────────────────────────
# Choose ONE of the options below depending on your email provider.

# Option 1: Resend (recommended for Next.js)
# Get your API key at https://resend.com
RESEND_API_KEY=re_YOUR_KEY_HERE

# Option 2: SMTP / Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Option 3: Formspree (no backend needed — paste your endpoint in Contact.tsx)
# No env var required — just update the fetch URL in the component.

# ─── SITE URL (for OG metadata) ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── GOOGLE ANALYTICS 4 ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-0BXNWRKRS
